{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjektAlpha",
  "version": "0.1.0",
  "identifier": "de.projektalpha.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProjektAlpha",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxMzA1QUNBREM2NDUwNkYKUldSdlVHVGN5bG93c1dVaHBseCt6d1JFYUVtMkx2WHp3bW5JbUprUit6dW4rSWZ0WDA5TlFqWE8K",
      "endpoints": [
        "https://github.com/kcamnaj/ProjektAlpha/releases/latest/download/latest.json"
      ]
    }
  }
}
